# OpenRouter
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Defaults to https://openrouter.ai/api/v1 if unset.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: shows up in your OpenRouter dashboard and unlocks slightly
# higher rate limits on the free tier.
OPENROUTER_REFERER=https://github.com/CSEP590A-SystemsForML/FinalProject
OPENROUTER_APP_TITLE=CSEP590A-FinalProject

# Optional retry / timeout knobs for the OpenRouter client.
# OPENROUTER_MAX_RETRIES=4
# OPENROUTER_TIMEOUT_SECONDS=60
